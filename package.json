{
  "name": "spoon-bot",
  "version": "1.0.0",
  "description": "스푼라디오 커맨드 봇",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.spoonbot.app",
    "productName": "스푼봇",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "installerLanguages": ["ko"],
      "language": "1042"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
